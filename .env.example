# =============================================================================
# Helix — Environment Variables Template
# =============================================================================
# Copy this file to .env.local and fill in your own values.
# Never commit .env.local or any file with real credentials.
# =============================================================================

# --- Supabase (required) -----------------------------------------------------
# Get these from: https://supabase.com/dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# --- AI Providers (at least one required for AI features) --------------------
# Groq — get from: https://console.groq.com/keys
GROQ_API_KEY=gsk_your-groq-api-key-here

# Google Gemini — get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# --- App URLs (required) -----------------------------------------------------
# In production (Vercel), set NEXT_PUBLIC_APP_URL=https://helixx.me
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- NextAuth (required for Google OAuth) ------------------------------------
# NEXTAUTH_URL must be set to the canonical app URL (matches NEXT_PUBLIC_APP_URL).
# Generate NEXTAUTH_SECRET with: openssl rand -base64 32
# In production (Vercel), set NEXTAUTH_URL=https://helixx.me (no trailing slash).
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-nextauth-secret-here

# Get these from the Google Cloud Console → APIs & Services → Credentials:
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# --- WebSocket Server (required for collaborative editing) -------------------
# Local dev default is ws://localhost:1234
# On Railway/Render, set this to your deployed ws-server URL
NEXT_PUBLIC_WS_URL=ws://localhost:1234

# The WS server process (Railway/Render) also needs these vars in its environment:
#   NEXTAUTH_URL                   (to call /api/auth/session for WS JWT validation)
#   SUPABASE_SERVICE_ROLE_KEY      (to validate share tokens via share_links table)
#   NEXT_PUBLIC_SUPABASE_URL       (used by share token validation fetch)
# On Railway/Render, set these as environment variables on the ws-server service.

# Optional: port for the standalone ws-server process (defaults to 1234)
PORT=1234

# --- Bundle Analysis (optional) ----------------------------------------------
# Set to "true" to enable @next/bundle-analyzer
ANALYZE=false
