# ============================================
# Helix — Environment Variables
# ============================================
# Copy this file to .env.local and fill in your values
# Never commit .env.local to git

# --------------------------------------------
# Supabase (https://supabase.com/dashboard)
# --------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# --------------------------------------------
# AI — Groq (https://console.groq.com/keys)
# Used for: Codebase Brain (GitHub repo analysis)
# --------------------------------------------
GROQ_API_KEY=your_groq_api_key

# --------------------------------------------
# AI — Gemini (https://aistudio.google.com)
# Used for: doc summaries, AI brain, devlog, README export
# --------------------------------------------
GEMINI_API_KEY=your_gemini_api_key

# --------------------------------------------
# App Config
# --------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Production example: https://helixx.me

# --------------------------------------------
# WebSocket Server (y-websocket relay)
# Local: ws://localhost:1234
# Production (Railway): wss://your-app.railway.app
# --------------------------------------------
NEXT_PUBLIC_WS_URL=ws://localhost:1234

# --------------------------------------------
# WebSocket Server Port (used in ws-server only)
# --------------------------------------------
PORT=1234
